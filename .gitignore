# Ignore environment files
.env
.env.local
.env.*.local

# Ignore IDE & OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Ignore build & dependency artifacts
backend/__pycache__/
backend/*.pyc
backend/venv/
backend/.venv/
frontend/node_modules/
frontend/dist/
frontend/.next/

# Ignore user uploads
backend/uploads/
*.mp4
*.webm
*.mov
*.avi

# Ignore logs
*.log
logs/

# Ignore secrets & credentials
*.key
*.pem
*.pub
secrets/
.env.production
api_keys.txt
auth.json
backend/auth.json

# Ignore local-only folder (contains sensitive files)
local-only/

# Ignore temporary files
*.tmp
*.bak
*.cache

# Python caching & testing
db/__pycache__/
db/**/__pycache__/
.pytest_cache/
.coverage
*.egg-info/
dist/
build/

# Compiled Python
*.egg
*.whl
